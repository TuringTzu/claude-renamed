#!/usr/bin/env bash
# claude-renamed — list, resume, rename, and unrename Claude Code sessions.
#
# Data source: scans ~/.claude/projects/**/*.jsonl for `type:"custom-title"`
# entries (Claude Code's own session-title format), which is authoritative.
#
# Optional path remapping for sessions whose `cwd` no longer exists on this
# machine (e.g. you moved your code from /srv/ on a Linux box to
# /Volumes/ssd/srv/ on a Mac). Config file:
#
#   ~/.config/claude-renamed/paths.json
#   {
#     "prefix_maps": [
#       {"from": "/old/prefix/", "to": "/new/prefix/"}
#     ],
#     "exact_maps": {
#       "/old/exact/path": "/new/exact/path"
#     }
#   }
#
# License: MIT. See https://github.com/TuringTzu/claude-renamed

set -euo pipefail

PROJECTS_DIR="${CLAUDE_PROJECTS_DIR:-$HOME/.claude/projects}"
CONFIG_FILE="${CLAUDE_RENAMED_CONFIG:-$HOME/.config/claude-renamed/paths.json}"
ARCHIVE_FILE="${CLAUDE_RENAMED_ARCHIVE:-$HOME/.config/claude-renamed/archived.json}"

if [[ ! -d "$PROJECTS_DIR" ]]; then
  echo "No projects directory found at $PROJECTS_DIR"
  echo "Set CLAUDE_PROJECTS_DIR if your sessions live elsewhere."
  exit 1
fi

# ── Collect renamed sessions from JSONL files ──────────────────────────────
collect_sessions() {
  # Speed: never let Python read the (often huge) transcript files. Two early-
  # stopping greps do the I/O in C — one pulls the first custom-title line per
  # file, the other the first cwd line — and Python only parses those small
  # outputs. Last-activity time comes from the file mtime, not the contents.
  #
  # grep -H prints "FILENAME:matchline"; session paths never contain ':', so the
  # first colon always separates filename from the JSON payload.
  local find_args=(-name '*.jsonl' -not -path '*/subagents/*' -not -path '*/tool-results/*' -not -path '*/workflows/*')
  CLAUDE_RENAMED_CONFIG="$CONFIG_FILE" python3 -c "
import json, sys, os
from datetime import datetime

titles_path, cwds_path = sys.argv[1], sys.argv[2]

# Load optional path-remapping config
config_file = os.environ.get('CLAUDE_RENAMED_CONFIG', '')
PREFIX_MAPS = []
EXACT_MAPS = {}
if config_file and os.path.exists(config_file):
    try:
        with open(config_file) as cf:
            cfg = json.load(cf)
        for pm in cfg.get('prefix_maps', []) or []:
            f = pm.get('from'); t = pm.get('to')
            if f and t:
                PREFIX_MAPS.append((f, t))
        em = cfg.get('exact_maps', {}) or {}
        if isinstance(em, dict):
            EXACT_MAPS = {str(k): str(v) for k, v in em.items()}
    except Exception:
        pass  # silently ignore malformed config

def parse_grep(path):
    # Map filepath -> parsed JSON dict of its first matching line.
    out = {}
    try:
        with open(path, errors='replace') as f:
            for line in f:
                fn, sep, rest = line.partition(':')
                if not sep:
                    continue
                if fn in out:
                    continue
                try:
                    out[fn] = json.loads(rest)
                except Exception:
                    pass
    except Exception:
        pass
    return out

titles = parse_grep(titles_path)
cwds = parse_grep(cwds_path)

def last_activity_ms(fp):
    # Real last-activity time = timestamp of the last event line. Read only the
    # tail so this stays fast, and don't trust file mtime (rsync mirrors and
    # other tools touch these files, which would scramble the ordering).
    try:
        with open(fp, 'rb') as f:
            f.seek(0, 2)
            size = f.tell()
            f.seek(max(0, size - 8192))
            tail = f.read().decode('utf-8', 'replace').splitlines()
    except Exception:
        tail = []
    for line in reversed(tail):
        if '\"timestamp\"' not in line:
            continue
        try:
            ts = json.loads(line).get('timestamp')
        except Exception:
            continue
        if not ts:
            continue
        if isinstance(ts, (int, float)):
            return int(ts)
        try:
            return int(datetime.fromisoformat(ts.replace('Z', '+00:00')).timestamp() * 1000)
        except Exception:
            continue
    try:
        return int(os.path.getmtime(fp) * 1000)  # fallback
    except Exception:
        return None

def remap(p):
    if p in EXACT_MAPS:
        return EXACT_MAPS[p]
    for old_prefix, new_prefix in PREFIX_MAPS:
        if p == old_prefix.rstrip('/'):
            return new_prefix.rstrip('/')
        if p.startswith(old_prefix):
            return new_prefix + p[len(old_prefix):]
    return p

sessions = {}
for filepath, td in titles.items():
    title = td.get('customTitle')
    if not title:
        continue
    sid = os.path.basename(filepath).replace('.jsonl', '')
    if '/' in sid or sid in sessions:
        continue
    project_dir = os.path.basename(os.path.dirname(filepath))
    proj_path = (cwds.get(filepath) or {}).get('cwd') or project_dir
    proj_path = remap(proj_path)
    last_ts = last_activity_ms(filepath)
    sessions[sid] = {
        'title': title,
        'project_dir': project_dir,
        'project_path': proj_path,
        'last_ts': last_ts,
        'filepath': filepath,
    }

# Oldest first → newest last, so the freshest session prints at the BOTTOM,
# closest to the prompt.
for sid, info in sorted(sessions.items(), key=lambda x: x[1]['last_ts'] or 0):
    last = datetime.fromtimestamp(info['last_ts'] / 1000).strftime('%Y-%m-%d %H:%M') if info['last_ts'] else '?'
    print(f\"{info['title']}\t{info['project_path']}\t{last}\t{sid}\t{info['filepath']}\t{info['project_dir']}\")
" \
    <(find "$PROJECTS_DIR" "${find_args[@]}" -print0 | xargs -0 grep -m1 -HF '"type":"custom-title"' 2>/dev/null) \
    <(find "$PROJECTS_DIR" "${find_args[@]}" -print0 | xargs -0 grep -m1 -HF '"cwd"' 2>/dev/null)
}

# ── Remove custom-title lines from a session JSONL ────────────────────────
unrename_session() {
  local filepath="$1"
  python3 -c "
import sys, json, tempfile, os

filepath = sys.argv[1]
lines_kept = []
removed = 0
with open(filepath) as f:
    for line in f:
        try:
            d = json.loads(line)
            if d.get('type') == 'custom-title':
                removed += 1
                continue
        except Exception:
            pass
        lines_kept.append(line)

if removed == 0:
    print('No custom-title entries found.')
    sys.exit(0)

tmpfd, tmppath = tempfile.mkstemp(dir=os.path.dirname(filepath))
with os.fdopen(tmpfd, 'w') as tmp:
    for line in lines_kept:
        tmp.write(line)
os.replace(tmppath, filepath)
print(f'Removed {removed} custom-title entries.')
" "$filepath"
}

# ── Update custom-title in a session JSONL ─────────────────────────────────
rename_session() {
  local filepath="$1"
  local new_name="$2"
  python3 -c "
import sys, json, tempfile, os, time

filepath = sys.argv[1]
new_name = sys.argv[2]

lines = []
has_title = False
with open(filepath) as f:
    for line in f:
        try:
            d = json.loads(line)
            if d.get('type') == 'custom-title':
                d['customTitle'] = new_name
                has_title = True
                lines.append(json.dumps(d, ensure_ascii=False) + '\n')
                continue
        except Exception:
            pass
        lines.append(line)

if not has_title:
    entry = {
        'type': 'custom-title',
        'customTitle': new_name,
        'timestamp': int(time.time() * 1000),
    }
    lines.append(json.dumps(entry, ensure_ascii=False) + '\n')

tmpfd, tmppath = tempfile.mkstemp(dir=os.path.dirname(filepath))
with os.fdopen(tmpfd, 'w') as tmp:
    for line in lines:
        tmp.write(line)
os.replace(tmppath, filepath)
print(f'Renamed to: {new_name}')
" "$filepath" "$new_name"
}

# ── Archive store (~/.config/claude-renamed/archived.json) ────────────────
# Archive state is kept separately from the session JSONL files so it never
# touches Claude Code's own data. The file is a JSON object: {"archived": [sid…]}.

# Archived session ids, loaded once into memory so per-session lookups don't
# each spawn a Python process (that made refreshing the list painfully slow).
declare -A ARCHIVED

# Read archived.json once into the ARCHIVED associative array.
load_archived() {
  ARCHIVED=()
  [[ -f "$ARCHIVE_FILE" ]] || return 0
  local sid
  while IFS= read -r sid; do
    [[ -n "$sid" ]] && ARCHIVED["$sid"]=1
  done < <(ARCHIVE_FILE="$ARCHIVE_FILE" python3 -c "
import json, os
f = os.environ['ARCHIVE_FILE']
try:
    with open(f) as fp:
        data = json.load(fp)
    ids = data.get('archived', []) if isinstance(data, dict) else data
except Exception:
    ids = []
print('\n'.join(str(i) for i in ids))
")
}

# Returns 0 if the given session id is archived, 1 otherwise (pure in-memory).
is_archived() {
  [[ -n "${ARCHIVED[$1]:-}" ]]
}

# Add ('add') or remove ('remove') a session id from the archive store.
set_archive() {
  local sid="$1" op="$2"
  mkdir -p "$(dirname "$ARCHIVE_FILE")"
  ARCHIVE_FILE="$ARCHIVE_FILE" python3 -c "
import json, os, sys
sid, op = sys.argv[1], sys.argv[2]
f = os.environ['ARCHIVE_FILE']
ids = []
if os.path.exists(f):
    try:
        with open(f) as fp:
            data = json.load(fp)
        ids = list(data.get('archived', []) if isinstance(data, dict) else data)
    except Exception:
        ids = []
s = set(ids)
if op == 'add':
    s.add(sid)
else:
    s.discard(sid)
with open(f, 'w') as fp:
    json.dump({'archived': sorted(s)}, fp, indent=2)
" "$sid" "$op"
}

# Reorder global `lines`: archived sessions first (top of screen), active ones
# last so the newest active session sits at the bottom near the prompt. Sets the
# global `archived_count` to the number of archived sessions.
partition_lines() {
  local l t p ts sid fp pd
  local active=() archived=()
  for l in "${lines[@]}"; do
    IFS=$'\t' read -r t p ts sid fp pd <<< "$l"
    if is_archived "$sid"; then
      archived+=("$l")
    else
      active+=("$l")
    fi
  done
  archived_count=${#archived[@]}
  lines=()
  if ((${#archived[@]})); then lines+=("${archived[@]}"); fi
  if ((${#active[@]})); then lines+=("${active[@]}"); fi
}

# Re-scan sessions from disk and re-partition into active/archived.
refresh_lines() {
  load_archived
  mapfile -t lines < <(collect_sessions)
  partition_lines
}

# ── Display list ───────────────────────────────────────────────────────────
show_list() {
  local active_count=$(( ${#lines[@]} - archived_count ))
  echo ""
  if (( archived_count > 0 )); then
    echo "  Claude Session Manager (${active_count} active, ${archived_count} archived)"
  else
    echo "  Claude Session Manager (${#lines[@]} named sessions)"
  fi
  echo "  ──────────────────────────────────────────────────"
  echo ""

  # Layout: archived rows first (dimmed, under an "Archived" heading), then the
  # active rows (under an "Active" heading) with the newest at the bottom near
  # the prompt. Headings only appear when there is anything archived.
  for i in "${!lines[@]}"; do
    if (( archived_count > 0 )); then
      if (( i == 0 )); then
        printf "  \033[2m── Archived ──────────────────────────────────────\033[0m\n"
      elif (( i == archived_count )); then
        echo ""
        printf "  \033[2m── Active ────────────────────────────────────────\033[0m\n"
      fi
    fi
    # Number from the bottom up: the newest (bottom) row is #1, increasing as you
    # go up. So the most-likely-to-resume session is always #1, next to the prompt.
    local label=$(( ${#lines[@]} - i ))
    IFS=$'\t' read -r title project_path last_ts sid filepath project_dir <<< "${lines[$i]}"
    if (( i < archived_count )); then
      # Archived rows: dimmed.
      printf "  \033[2m%3d  %-35s  %-40s  %s\033[0m\n" \
        "$label" "$title" "$project_path" "$last_ts"
    else
      printf "  \033[1;36m%3d\033[0m  \033[1m%-35s\033[0m  \033[2m%-40s  %s\033[0m\n" \
        "$label" "$title" "$project_path" "$last_ts"
    fi
  done

  echo ""
  echo "  Commands:  <number>        resume session"
  echo "             d <number>      unrename (remove name, keep session)"
  echo "             r <number>      rename to new name"
  echo "             a <number>      archive (move to Archived)"
  echo "             ua <number>     unarchive"
  echo "             q               quit"
  echo ""
}

# ── Main loop ──────────────────────────────────────────────────────────────
main() {
  refresh_lines

  if [[ ${#lines[@]} -eq 0 ]]; then
    echo "No renamed sessions found."
    echo "Tip: in a Claude Code session, use the /name slash command (or rename"
    echo "from the UI) to give a session a sticky name, then it will show up here."
    exit 0
  fi

  show_list

  while true; do
    read -rp "  > " input

    if [[ -z "$input" || "$input" == "q" ]]; then
      exit 0
    fi

    local cmd num
    if [[ "$input" =~ ^ua[[:space:]]+([0-9]+)$ ]]; then
      cmd="unarchive"
      num="${BASH_REMATCH[1]}"
    elif [[ "$input" =~ ^a[[:space:]]+([0-9]+)$ ]]; then
      cmd="archive"
      num="${BASH_REMATCH[1]}"
    elif [[ "$input" =~ ^d[[:space:]]+([0-9]+)$ ]]; then
      cmd="unrename"
      num="${BASH_REMATCH[1]}"
    elif [[ "$input" =~ ^r[[:space:]]+([0-9]+)$ ]]; then
      cmd="rename"
      num="${BASH_REMATCH[1]}"
    elif [[ "$input" =~ ^([0-9]+)$ ]]; then
      cmd="resume"
      num="${BASH_REMATCH[1]}"
    else
      echo "  Invalid input."
      continue
    fi

    if (( num < 1 || num > ${#lines[@]} )); then
      echo "  Invalid number."
      continue
    fi

    # Numbers count from the bottom (newest = 1), so invert to get the array index.
    local idx=$(( ${#lines[@]} - num ))
    IFS=$'\t' read -r title project_path last_ts sid filepath project_dir <<< "${lines[$idx]}"

    case "$cmd" in
      resume)
        echo ""
        echo "  Resuming: $title ($sid)"
        echo ""
        cd "$project_path" 2>/dev/null || true
        exec claude --resume "$sid"
        ;;
      unrename)
        unrename_session "$filepath"
        echo "  Removed: $title"
        echo ""
        refresh_lines
        if [[ ${#lines[@]} -eq 0 ]]; then
          echo "  No named sessions remaining."
          exit 0
        fi
        show_list
        ;;
      rename)
        read -rp "  New name for '$title': " new_name
        if [[ -n "$new_name" ]]; then
          rename_session "$filepath" "$new_name"
          echo ""
          refresh_lines
          show_list
        else
          echo "  Cancelled."
        fi
        ;;
      archive)
        set_archive "$sid" add
        echo "  Archived: $title"
        echo ""
        refresh_lines
        show_list
        ;;
      unarchive)
        set_archive "$sid" remove
        echo "  Unarchived: $title"
        echo ""
        refresh_lines
        show_list
        ;;
    esac
  done
}

main
